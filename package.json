{
  "name": "llmstore.pro",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev": "concurrently -n shared,backend,frontend -c blue,green,yellow \"npm run dev -w @llmstore/shared\" \"npm run dev -w @llmstore/backend\" \"npm run dev -w @llmstore/frontend\"",
    "build": "npm run build -w @llmstore/shared && npm run build -w @llmstore/backend && npm run build -w @llmstore/frontend",
    "build:shared": "npm run build -w @llmstore/shared",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run db:generate -w @llmstore/backend",
    "db:migrate": "npm run db:migrate -w @llmstore/backend",
    "db:push": "npm run db:push -w @llmstore/backend",
    "db:seed": "npm run db:seed -w @llmstore/backend",
    "db:studio": "npm run db:studio -w @llmstore/backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}
